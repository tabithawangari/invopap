# ─── Supabase (Required) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App URL (Recommended) ──────────────────────────────────
# Used for CSRF validation, M-Pesa callbacks, and OAuth redirect
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── M-Pesa / Daraja (Required for payments) ────────────────
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your-daraja-consumer-key
MPESA_CONSUMER_SECRET=your-daraja-consumer-secret
MPESA_PASSKEY=your-lipa-na-mpesa-passkey
MPESA_SHORTCODE=174379
# Optional: Override callback URL
# MPESA_CALLBACK_URL=https://your-domain.com/api/payments/callback?token=your-secret
# Optional: Secret token for verifying Safaricom callbacks
# MPESA_CALLBACK_SECRET=random-string-here

# ─── Rate Limiting (Recommended for production) ─────────────
# Without Redis, rate limiting uses in-memory fallback (resets on restart)
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ─── Admin Dashboard ────────────────────────────────────────
# Required to access /admin
ADMIN_SECRET=change-me-to-a-long-random-string

# ─── Sentry (Recommended for production) ────────────────────
# SENTRY_DSN=https://xxxxx@oxxxx.ingest.sentry.io/xxxxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@oxxxx.ingest.sentry.io/xxxxx
# SENTRY_ORG=invopap
# SENTRY_PROJECT=invopap
# SENTRY_AUTH_TOKEN=sntrys_xxxxx
